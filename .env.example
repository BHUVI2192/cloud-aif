# ---- Supabase Postgres ----
# Get these from Supabase: Project Settings -> Database -> Connection string
# DATABASE_URL = the "Transaction" pooler URL (port 6543), append ?pgbouncer=true
# DIRECT_URL   = the "Session"/direct URL (port 5432), used for migrations
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[DB-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[DB-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ---- Auth ----
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ---- Optional Google OAuth (dev credential login works without these) ----
# Create credentials at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ---- Cron security (for /api/system/auto-assign) ----
# Generate with: openssl rand -hex 32  (or any long random string)
CRON_SECRET=your-cron-secret-here

# ---- Google SMTP (Free Tier Email Alerts) ----
# 1. Enable 2-Step Verification on your Gmail account.
# 2. Go to Security -> App Passwords and generate a 16-character pass.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-google-app-password-here"
SMTP_FROM="Cloud AIF <your-email@gmail.com>"

# ---- Google Maps JS API (for interactive maps pin picker) ----
# Create an API key at https://console.cloud.google.com/
# Make sure to enable: Maps JavaScript API, Geocoding API, Places API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key-here"
